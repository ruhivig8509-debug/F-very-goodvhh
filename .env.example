# ─────────────────────────────────────────────────────────────
#  Ruhi Ji Bot — Environment Variables
#  Copy → .env  aur real values fill karo
#  On Render: Dashboard → Environment tab
# ─────────────────────────────────────────────────────────────

# ── Telegram ─────────────────────────────────────────────────
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
# Get from: @BotFather → /newbot

OWNER_ID=YOUR_TELEGRAM_NUMERIC_USER_ID
# Get from: @userinfobot

# ── HuggingFace (LLM) ────────────────────────────────────────
HF_TOKEN=YOUR_HUGGINGFACE_TOKEN_HERE
# Get from: huggingface.co/settings/tokens

# ── Database (NeonDB) ────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require
# Get from: console.neon.tech → your project → Connection string

# ── Render (auto-set by Render, add manually for local testing) ──
RENDER_EXTERNAL_URL=https://YOUR-SERVICE-NAME.onrender.com
# Render sets this automatically in production — no need to add on dashboard
# For LOCAL testing only: set this to your ngrok/tunnel URL
